# SEO Analyzer — Variables de entorno
# Copiar a .env.local y completar los valores

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── PageSpeed Insights API (Lighthouse real) ────────────────────────────────
# Gratis en: https://console.cloud.google.com → Habilitar "PageSpeed Insights API"
# → Credenciales → Crear clave de API
PAGESPEED_API_KEY=

# ─── Google AI Studio (Gemini) ───────────────────────────────────────────────
# Gratis en: https://aistudio.google.com/app/apikey
# Modelo usado: gemini-1.5-flash (sin costo en tier gratuito)
GEMINI_API_KEY=
